{
  "name": "noseroast",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @noseroast/web",
    "dev:mobile": "npm run dev -w @noseroast/mobile",
    "build:web": "npm run build -w @noseroast/web",
    "build:mobile": "npm run build -w @noseroast/mobile",
    "android:sync": "npm run build:mobile && cd apps/mobile && npx cap sync android",
    "android:open": "cd apps/mobile && npx cap open android",
    "backend:dev": "npm run dev -w @noseroast/signaling",
    "backend:build": "npm run build -w @noseroast/signaling",
    "backend:start": "npm run start -w @noseroast/signaling"
  }
}
